generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           Int             @id @default(autoincrement())
  email                        String          @unique
  username                     String          @unique
  hashedPassword               String
  name                         String?
  lastName                     String?
  chileanRutNumber             String?
  color                        String          @default("#7ad9c5")
  createdAt                    DateTime        @default(now())
  createdBy                    Int             @default(0)
  lastLogin                    DateTime?
  twoFactorEnabled             Boolean         @default(false)
  twoFactorSecret              String?
  twoFactorRecoveryCode        String?
  twoFactorRecoveryCodeExpires DateTime?
  passwordResetCode            String?
  passwordResetCodeExpires     DateTime?
  userEnabledTwoFactor         Boolean         @default(false)
  createdCalendarEvents        CalendarEvent[]
  createdCompanies             Company[]
  createdContacts              Contact[]
  createdEmailTemplates        EmailTemplate[]
  createdInvoices              Invoice[]
  createdStrideDocuments       StrideDocument[]
  userRoles                    UserRole[]
}

model StrideDocument {
  id           Int      @id @default(autoincrement())
  name         String
  mdR2Key      String?
  pdfR2Key     String?
  mdFileSize   Int?
  pdfFileSize  Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdById  Int?
  createdBy    User?    @relation(fields: [createdById], references: [id])
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  userRoles UserRole[]
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model EmailSender {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
}

model EmailTemplate {
  id               Int                    @id @default(autoincrement())
  description      String?
  subject          String?
  content          String?
  destinationEmail Json?
  ccEmail          Json?
  bccEmail         Json?
  fromEmail        String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  createdById      Int?
  createdBy        User?                  @relation(fields: [createdById], references: [id])
  contacts         EmailTemplateContact[]
  invoices         Invoice[]
}

model EmailTemplateContact {
  id              Int           @id @default(autoincrement())
  emailTemplateId Int
  contactId       Int
  type            String
  contact         Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  emailTemplate   EmailTemplate @relation(fields: [emailTemplateId], references: [id], onDelete: Cascade)

  @@unique([emailTemplateId, contactId, type])
  @@index([emailTemplateId])
  @@index([contactId])
}

model Domain {
  id        Int      @id @default(autoincrement())
  domain    String   @unique
  createdAt DateTime @default(now())
}

model Configuration {
  id                         Int      @id @default(autoincrement())
  twoFactorEnabled           Boolean  @default(false)
  updatedAt                  DateTime @updatedAt
  appName                    String   @default("PavleTek")
  recoveryEmailSenderId      Int?
  inquiriesNotificationEmail String?
  notificationEmailSenderId  Int?
}

model Currency {
  id           Int           @id @default(autoincrement())
  name         String
  abbreviation String        @unique
  createdAt    DateTime      @default(now())
  bankAccounts BankAccount[]
  companies    Company[]
  contacts     Contact[]
  invoices     Invoice[]
}

model Language {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Country {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
}

model Contact {
  id                    Int                    @id @default(autoincrement())
  firstName             String?
  lastName              String?
  chileanRutNumber      String?
  phoneNumber           String?
  email                 String?
  color                 String                 @default("#7ad9c5")
  notes                 String?
  taxID                 String?
  roleInCompany         String?
  address               Json?
  country               String?
  language              String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  currencyId            Int?
  associatedCompanyId   Int?
  defaultBankAccountId  Int?
  createdById           Int?
  bankAccounts          BankAccount[]          @relation("ContactBankAccount")
  companiesAsDefault    Company[]              @relation("CompanyDefaultContact")
  associatedCompany     Company?               @relation("ContactCompany", fields: [associatedCompanyId], references: [id])
  createdBy             User?                  @relation(fields: [createdById], references: [id])
  currency              Currency?              @relation(fields: [currencyId], references: [id])
  defaultBankAccount    BankAccount?           @relation("ContactDefaultBankAccount", fields: [defaultBankAccountId], references: [id])
  emailTemplateContacts EmailTemplateContact[]
  invoicesFrom          Invoice[]              @relation("InvoiceFromContact")
  invoicesTo            Invoice[]              @relation("InvoiceToContact")
}

model Company {
  id                 Int           @id @default(autoincrement())
  displayName        String?
  legalName          String?
  taxId              String?
  website            String?
  businessType       String?
  color              String        @default("#7ad9c5")
  address            Json?
  country            String?
  language           String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  currencyId         Int?
  defaultContactId   Int?
  createdById        Int?
  bankAccounts       BankAccount[] @relation("CompanyBankAccount")
  createdBy          User?         @relation(fields: [createdById], references: [id])
  currency           Currency?     @relation(fields: [currencyId], references: [id])
  defaultContact     Contact?      @relation("CompanyDefaultContact", fields: [defaultContactId], references: [id])
  associatedContacts Contact[]     @relation("ContactCompany")
  invoicesFrom       Invoice[]     @relation("InvoiceFromCompany")
  invoicesTo         Invoice[]     @relation("InvoiceToCompany")
}

model BankAccount {
  id                Int       @id @default(autoincrement())
  bankName          String?
  accountHolder     String?
  accountNumber     String?
  accountType       String?
  swiftCode         String?
  ibanCode          String?
  routingNumber     String?
  bankCode          String?
  branchName        String?
  email             String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  currencyId        Int?
  country           String?
  ownerContactId    Int?
  ownerCompanyId    Int?
  currency          Currency? @relation(fields: [currencyId], references: [id])
  ownerCompany      Company?  @relation("CompanyBankAccount", fields: [ownerCompanyId], references: [id])
  ownerContact      Contact?  @relation("ContactBankAccount", fields: [ownerContactId], references: [id])
  contactsAsDefault Contact[] @relation("ContactDefaultBankAccount")
}

model Invoice {
  id                   Int            @id @default(autoincrement())
  invoiceNumber        Int
  date                 DateTime
  subtotal             Float
  taxRate              Float
  taxAmount            Float
  total                Float
  isTemplate           Boolean        @default(false)
  templateName         String?
  sent                 Boolean        @default(false)
  items                Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  fromCompanyId        Int?
  fromContactId        Int?
  toCompanyId          Int?
  toContactId          Int?
  currencyId           Int?
  createdById          Int?
  emailTemplateId      Int?
  name                 String?
  description          String?
  hasASDocument        Boolean        @default(false)
  ASDocument           Json?
  asPdfR2Key           String?
  documentsGeneratedAt DateTime?
  invoicePdfR2Key      String?
  scheduledEmailData   Json?
  scheduledError       String?
  scheduledSendAt      DateTime?
  scheduledSentAt      DateTime?
  scheduledStatus      String?
  platformUploadAt          DateTime?
  platformUploadError       String?
  platformUploadStatus      String?
  platformUploadScheduledAt DateTime?
  createdBy            User?          @relation(fields: [createdById], references: [id])
  currency             Currency?      @relation(fields: [currencyId], references: [id])
  emailTemplate        EmailTemplate? @relation(fields: [emailTemplateId], references: [id])
  fromCompany          Company?       @relation("InvoiceFromCompany", fields: [fromCompanyId], references: [id])
  fromContact          Contact?       @relation("InvoiceFromContact", fields: [fromContactId], references: [id])
  toCompany            Company?       @relation("InvoiceToCompany", fields: [toCompanyId], references: [id])
  toContact            Contact?       @relation("InvoiceToContact", fields: [toContactId], references: [id])
}

model CalendarEvent {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  timestamp   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id])
}

model CalendarColorConfig {
  id             Int      @id @default(autoincrement())
  colorStartDate DateTime
  colorOne       String   @default("#ef4444")
  colorTwo       String   @default("#22c55e")
  updatedAt      DateTime @updatedAt
}

model QuoteInquiry {
  id              String            @id @default(cuid())
  status          String            @default("new")
  fullName        String
  company         String?
  role            String?
  email           String
  phone           String?
  timezone        String?
  contactMethod   String
  contactTime     String?
  projectType     String
  projectCategory String
  projectName     String
  description     String            @db.Text
  goals           String            @db.Text
  users           String?           @db.Text
  metrics         String?           @db.Text
  keyFeatures     Json
  technologyIds   Json
  startDate       String?
  endDate         String?
  urgency         String
  deadlineHard    Boolean           @default(false)
  budgetRange     String
  fundingSource   String?
  engineerCount   Int?
  seniorityJunior Int               @default(0)
  seniorityMid    Int               @default(0)
  senioritySenior Int               @default(0)
  seniorityLead   Int               @default(0)
  requiredSkills  String?
  repoUrl         String?
  currentStack    String?           @db.Text
  painPoints      String?           @db.Text
  ndaRequested    Boolean           @default(false)
  referral        String?
  notes           String?           @db.Text
  adminNotes      String?           @db.Text
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  attachments     QuoteAttachment[]

  @@index([createdAt])
  @@index([status])
}

model QuoteAttachment {
  id          String       @id @default(cuid())
  inquiryId   String
  inquiry     QuoteInquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  fileName    String
  contentType String
  size        Int
  r2Key       String       @unique
  createdAt   DateTime     @default(now())

  @@index([inquiryId])
}

model MeetingRequest {
  id         String   @id @default(cuid())
  status     String   @default("new")
  fullName   String
  email      String
  message    String?  @db.Text
  adminNotes String?  @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
}
